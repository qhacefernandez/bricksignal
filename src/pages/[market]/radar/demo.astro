---
import { getMarket, isValidMarketSlug } from '@/config/markets';
import { marketStaticPaths } from '@/lib/staticPaths';
import MarketLayout from '@/layouts/MarketLayout.astro';
import MarketRadarDemo from '@/components/market/MarketRadarDemo';
import type { MarketSlug } from '@/config/types';

export function getStaticPaths() {
  return marketStaticPaths();
}

const { market: marketParam } = Astro.params;
if (!marketParam || !isValidMarketSlug(marketParam)) return Astro.redirect('/404');
const market = getMarket(marketParam as MarketSlug);
---

<MarketLayout market={market.slug} pathSegment="radar/demo" title={`Radar Demo — ${market.nativeName}`}>
  <MarketRadarDemo client:load market={market} />
</MarketLayout>
