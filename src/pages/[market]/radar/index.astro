---
import { getMarket, isValidMarketSlug } from '@/config/markets';
import { marketStaticPaths } from '@/lib/staticPaths';
import MarketLayout from '@/layouts/MarketLayout.astro';
import RadarShowcasePage from '@/components/market/RadarShowcasePage';
import { getRadarPageCopy } from '@/i18n/radarCopy';
import type { MarketSlug } from '@/config/types';

export function getStaticPaths() {
  return marketStaticPaths();
}

const { market: marketParam } = Astro.params;
if (!marketParam || !isValidMarketSlug(marketParam)) return Astro.redirect('/404');
const market = getMarket(marketParam as MarketSlug);
const radarMeta = getRadarPageCopy(market.language);
---

<MarketLayout market={market.slug} pathSegment="radar" title={`${radarMeta.pageTitle} — ${market.nativeName}`} description={radarMeta.pageDescription}>
  <RadarShowcasePage client:load market={market} />
</MarketLayout>
