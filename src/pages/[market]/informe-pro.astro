---
import { getMarket, isValidMarketSlug } from '@/config/markets';
import { marketStaticPaths } from '@/lib/staticPaths';
import MarketLayout from '@/layouts/MarketLayout.astro';
import ProReportShowcasePage from '@/components/market/ProReportShowcasePage';
import { getProReportPageCopy } from '@/i18n/proReportCopy';
import type { MarketSlug } from '@/config/types';

export function getStaticPaths() {
  return marketStaticPaths();
}

const { market: marketParam } = Astro.params;
if (!marketParam || !isValidMarketSlug(marketParam)) return Astro.redirect('/404');
const market = getMarket(marketParam as MarketSlug);
const proMeta = getProReportPageCopy(market.language);
---

<MarketLayout
  market={market.slug}
  pathSegment="informe-pro"
  title={`${proMeta.pageTitle} — ${market.nativeName} | BrickSignal`}
  description={proMeta.pageDescription}
>
  <ProReportShowcasePage client:load market={market} />
</MarketLayout>
