---
import { getMarket, isValidMarketSlug } from '@/config/markets';
import { marketStaticPaths } from '@/lib/staticPaths';
import MarketLayout from '@/layouts/MarketLayout.astro';
import { marketPath } from '@/i18n/routes';
import type { MarketSlug } from '@/config/types';

export function getStaticPaths() {
  return marketStaticPaths();
}

const { market: marketParam } = Astro.params;
if (!marketParam || !isValidMarketSlug(marketParam)) return Astro.redirect('/404');
const market = getMarket(marketParam as MarketSlug);
---

<MarketLayout market={market.slug} pathSegment="cancel" noindex={true}>
  <div class="mx-auto max-w-lg text-center">
    <h1 class="text-2xl font-bold">Payment cancelled</h1>
    <p class="mt-3 text-slate-600">No charge was made.</p>
    <a href={marketPath(market.slug, 'simulator')} class="mt-6 inline-block rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white">Back to simulator</a>
  </div>
</MarketLayout>
