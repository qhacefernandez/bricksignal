---
import { getMarket, isValidMarketSlug } from '@/config/markets';
import { marketStaticPaths } from '@/lib/staticPaths';
import MarketLayout from '@/layouts/MarketLayout.astro';
import MarketHero from '@/components/market/MarketHero';
import CountryLaunchStatus from '@/components/market/CountryLaunchStatus';
import type { MarketSlug } from '@/config/types';

export function getStaticPaths() {
  return marketStaticPaths();
}

const { market: marketParam } = Astro.params;
if (!marketParam || !isValidMarketSlug(marketParam)) return Astro.redirect('/404');
const market = getMarket(marketParam as MarketSlug);
---

<MarketLayout market={market.slug} pathSegment="">
  {market.seo.faq && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: market.seo.faq.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    })} />
  )}
  <MarketHero client:load market={market} />
  <div class="mt-6 flex justify-center">
    <CountryLaunchStatus client:load market={market} />
  </div>
</MarketLayout>
