STRIPE_SECRET_KEY=sk_test_...
# Local con `npm run dev:netlify`: http://localhost:8888
# Producción Netlify: https://TU-SITIO.netlify.app (o tu dominio custom, sin barra final)
PUBLIC_SITE_URL=http://localhost:8888

# Report prices by currency — use Price ID (price_...), NOT Product ID (prod_...)
STRIPE_PRICE_REPORT_EUR=price_...
STRIPE_PRICE_REPORT_GBP=price_...
STRIPE_PRICE_REPORT_USD=price_...
STRIPE_PRICE_REPORT_MXN=price_...
STRIPE_PRICE_REPORT_AUD=price_...

# Radar subscription prices by currency
STRIPE_PRICE_RADAR_BASIC_EUR=price_...
STRIPE_PRICE_RADAR_BASIC_GBP=price_...
STRIPE_PRICE_RADAR_BASIC_USD=price_...
STRIPE_PRICE_RADAR_BASIC_MXN=price_...
STRIPE_PRICE_RADAR_BASIC_AUD=price_...

STRIPE_PRICE_RADAR_PRO_EUR=price_...
STRIPE_PRICE_RADAR_PRO_GBP=price_...
STRIPE_PRICE_RADAR_PRO_USD=price_...
STRIPE_PRICE_RADAR_PRO_MXN=price_...
STRIPE_PRICE_RADAR_PRO_AUD=price_...

STRIPE_PRICE_RADAR_INVESTOR_EUR=price_...
STRIPE_PRICE_RADAR_INVESTOR_GBP=price_...
STRIPE_PRICE_RADAR_INVESTOR_USD=price_...
STRIPE_PRICE_RADAR_INVESTOR_MXN=price_...
STRIPE_PRICE_RADAR_INVESTOR_AUD=price_...

STRIPE_WEBHOOK_SECRET=whsec_...
ENABLE_RADAR_EARLY_ACCESS=false
ENABLE_AUTHORIZED_LISTING_PROVIDER=false

# Optional — loaded only after cookie consent (Accept cookies)
PUBLIC_PLAUSIBLE_DOMAIN=
